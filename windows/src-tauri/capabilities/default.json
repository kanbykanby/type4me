{
  "identifier": "default",
  "description": "Default capabilities for Type4Me",
  "windows": ["settings", "floating-bar"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:event:default",
    "core:tray:default",
    "shell:allow-open",
    "updater:default"
  ]
}
